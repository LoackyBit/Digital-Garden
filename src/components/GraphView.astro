---
import { withBase } from "@/utils/withBase";

const { dataUrl = withBase("/graph/backlinks.json") } = Astro.props as {
  dataUrl?: string;
};
---

<section class="rounded-2xl border border-border bg-background/70 p-4">
  <div class="mb-4">
    <h2 class="text-xl font-semibold">Graph View</h2>
    <p class="text-sm text-foreground/75">
      Vista backlink interattiva con force-directed graph (D3.js).
    </p>
  </div>

  <div
    id="graph-view-root"
    data-graph-url={dataUrl}
    data-base-url={import.meta.env.BASE_URL ?? "/"}
    class="h-[70svh] min-h-[420px] w-full rounded-xl border border-border"
  />
</section>

<script is:inline src="https://cdn.jsdelivr.net/npm/d3@7"></script>

<script is:inline>
  const stageColor = {
    "raw 🗂️": "#6ee7b7",
    "learning 🧩": "#34d399",
    "fine-tuned 🧠": "#047857",
  };

  const getRoot = () => document.getElementById("graph-view-root");

  const renderGraph = async root => {
    const d3 = window.d3;

    if (!d3) {
      root.innerHTML =
        '<p style="padding:1rem;color:var(--foreground)">D3 non disponibile.</p>';
      return;
    }

    // Prevent duplicated SVGs when the page is re-initialized after client-side navigation.
    root.innerHTML = "";

    const graphUrl =
      root.getAttribute("data-graph-url") ??
      root.getAttribute("data-base-url") + "graph/backlinks.json";
    const response = await fetch(graphUrl);

    if (!response.ok) {
      throw new Error(`HTTP ${response.status} while loading ${graphUrl}`);
    }

    const graphData = await response.json();

    if (!Array.isArray(graphData?.nodes) || !Array.isArray(graphData?.links)) {
      throw new Error("Formato backlinks.json non valido: attesi array 'nodes' e 'links'.");
    }

    const nodes = graphData.nodes
      .filter(node => node && typeof node.id === "string")
      .map(node => ({ ...node }));

    const nodeIds = new Set(nodes.map(node => node.id));
    const links = graphData.links
      .filter(link => link && typeof link.source === "string" && typeof link.target === "string")
      .filter(link => nodeIds.has(link.source) && nodeIds.has(link.target))
      .map(link => ({ ...link }));

    if (!nodes.length) {
      throw new Error("Nessun nodo valido trovato nel dataset del grafo.");
    }

    const toBaseUrl = url => {
      if (!url || typeof url !== "string") {
        return url;
      }

      if (/^https?:\/\//.test(url)) {
        return url;
      }

      const baseUrl = root.getAttribute("data-base-url") ?? "/";
      const normalizedBase =
        baseUrl !== "/" && baseUrl.endsWith("/")
          ? baseUrl.slice(0, -1)
          : baseUrl;
      const normalizedPath = url.startsWith("/") ? url : `/${url}`;

      if (
        normalizedBase === "/" ||
        normalizedPath === normalizedBase ||
        normalizedPath.startsWith(`${normalizedBase}/`)
      ) {
        return normalizedPath;
      }

      return `${normalizedBase}${normalizedPath}`;
    };

    const width = root.clientWidth;
    const height = root.clientHeight;

    const svg = d3
      .select(root)
      .append("svg")
      .attr("viewBox", `0 0 ${width} ${height}`)
      .attr("width", width)
      .attr("height", height)
      .style("background", "var(--background)");

    const link = svg
      .append("g")
      .attr("stroke", "var(--muted)")
      .attr("stroke-opacity", 0.6)
      .selectAll("line")
      .data(links)
      .join("line")
      .attr("stroke-width", 1.5);

    const node = svg
      .append("g")
      .selectAll("circle")
      .data(nodes)
      .join("circle")
      .attr("r", 8)
      .attr("fill", d => stageColor[d.stage ?? "raw 🗂️"] ?? stageColor["raw 🗂️"])
      .attr("stroke", "var(--border)")
      .attr("stroke-width", 1.5)
      .style("cursor", "pointer")
      .on("click", (_, d) => {
        if (d.url) {
          window.location.href = toBaseUrl(d.url);
        }
      });

    const label = svg
      .append("g")
      .selectAll("text")
      .data(nodes)
      .join("text")
      .text(d => d.title)
      .attr("font-size", 11)
      .attr("fill", "var(--foreground)")
      .attr("dx", 12)
      .attr("dy", 4)
      .style("pointer-events", "none");

    const simulation = d3
      .forceSimulation(nodes)
      .force(
        "link",
        d3
          .forceLink(links)
          .id(d => d.id)
          .distance(80)
      )
      .force("charge", d3.forceManyBody().strength(-160))
      .force("center", d3.forceCenter(width / 2, height / 2));

    const drag = d3
      .drag()
      .on("start", (event, d) => {
        if (!event.active) {
          simulation.alphaTarget(0.2).restart();
        }
        d.fx = d.x;
        d.fy = d.y;
      })
      .on("drag", (event, d) => {
        d.fx = event.x;
        d.fy = event.y;
      })
      .on("end", (event, d) => {
        if (!event.active) {
          simulation.alphaTarget(0);
        }
        d.fx = null;
        d.fy = null;
      });

    node.call(drag);

    simulation.on("tick", () => {
      link
        .attr("x1", d => d.source.x ?? 0)
        .attr("y1", d => d.source.y ?? 0)
        .attr("x2", d => d.target.x ?? 0)
        .attr("y2", d => d.target.y ?? 0);

      node.attr("cx", d => d.x ?? 0).attr("cy", d => d.y ?? 0);

      label.attr("x", d => d.x ?? 0).attr("y", d => d.y ?? 0);
    });
  };

  const initGraphView = () => {
    const root = getRoot();

    if (!root) {
      return;
    }

    renderGraph(root).catch(error => {
      root.innerHTML =
        `<p style="padding:1rem;color:var(--foreground)">Impossibile caricare il grafo backlink. ${String(error)}</p>`;
    });
  };

  document.addEventListener("astro:page-load", initGraphView);

  if (document.readyState === "complete" || document.readyState === "interactive") {
    initGraphView();
  } else {
    document.addEventListener("DOMContentLoaded", initGraphView, { once: true });
  }
</script>
