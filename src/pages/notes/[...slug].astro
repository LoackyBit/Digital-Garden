---
import { getCollection, render } from "astro:content";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import StageTag from "@/components/StageTag.astro";
import Layout from "@/layouts/Layout.astro";

export async function getStaticPaths() {
  const notes = await getCollection("notes", entry => !entry.data.draft);

  return notes.map(note => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
---

<Layout
  title={`${note.data.title} | Garden`}
  description={note.data.summary ?? "Nota del Digital Garden"}
>
  <Header />
  <main class="app-layout py-8">
    <article class="app-prose max-w-app">
      <div class="mb-3 flex flex-wrap items-center gap-3">
        <h1 class="m-0 text-3xl font-bold text-accent">{note.data.title}</h1>
        <StageTag stage={note.data.stage} />
      </div>

      <p class="text-sm text-foreground/75">
        {note.data.date.toLocaleDateString("it-IT")}
      </p>

      {note.data.tags.length > 0 && (
        <ul class="mt-2 flex flex-wrap gap-2 p-0">
          {note.data.tags.map(tag => (
            <li class="list-none rounded-full border border-border px-2 py-0.5 text-xs">#{tag}</li>
          ))}
        </ul>
      )}

      <hr class="my-6 border-dashed" />
      <Content />
    </article>
  </main>
  <Footer />
</Layout>
