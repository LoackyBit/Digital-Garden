---
import { getCollection } from "astro:content";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import TilList from "@/components/TilList.astro";
import Layout from "@/layouts/Layout.astro";

const tilEntries = (await getCollection("til")).filter(entry => !entry.data.draft);
---

<Layout title="TIL | AstroPaper" description="Today I Learned: appunti rapidi per categoria.">
  <Header />
  <main class="app-layout py-8">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-accent">Today I Learned</h1>
      <p class="mt-2 text-sm text-foreground/80">
        Note corte, pratiche e versionate nel tempo.
      </p>
    </header>

    <TilList entries={tilEntries} />
  </main>
  <Footer />
</Layout>
