---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import StageTag, { type StageValue } from "@/components/StageTag.astro";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const notes = (await getCollection("notes", ({ data }) => !data.draft)).sort(
  (left, right) => right.data.date.getTime() - left.data.date.getTime()
);

const tilEntries = (await getCollection("til", ({ data }) => !data.draft)).sort(
  (left, right) => right.data.date.getTime() - left.data.date.getTime()
);

const stageOrder: StageValue[] = ["raw 🗂️", "learning 🧩", "fine-tuned 🧠"];
const stageCount = Object.fromEntries(
  stageOrder.map(stage => [stage, notes.filter(note => note.data.stage === stage).length])
) as Record<StageValue, number>;

const recentNotes = notes.slice(0, SITE.postPerIndex);
const recentTil = tilEntries.slice(0, SITE.postPerIndex);
---

<Layout
  title={`${SITE.title} | Digital Garden`}
  description="Digital Garden personale con note evolutive e TIL in italiano."
>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout py-8">
    <section class="border-b border-border pb-8">
      <h1 class="text-4xl font-bold text-accent sm:text-5xl">Digital Garden</h1>
      <p class="mt-4 max-w-2xl text-foreground/85">
        Appunti in evoluzione continua: idee grezze, concetti in apprendimento e note rifinite.
        Niente contenuti statici da template, solo materiale del tuo percorso.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        {stageOrder.map(stage => (
          <div class="flex items-center gap-2 rounded-xl border border-border px-3 py-2">
            <StageTag stage={stage} />
            <span class="text-sm text-foreground/80">{stageCount[stage]} note</span>
          </div>
        ))}
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <LinkButton href="/garden">
          Vai al Garden
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
        <LinkButton href="/til">
          Apri TIL
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
        <LinkButton href="/graph">
          Vedi Graph
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </LinkButton>
      </div>
    </section>

    <section class="pt-10 pb-6">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-2xl font-semibold tracking-wide">Ultime note</h2>
        <a href="/garden" class="text-sm hover:text-accent">Tutte le note</a>
      </div>

      {
        recentNotes.length === 0 ? (
          <p class="text-sm text-foreground/70">Nessuna nota pubblicata.</p>
        ) : (
          <ul class="grid gap-4 sm:grid-cols-2">
            {recentNotes.map(note => (
              <li class="rounded-xl border border-border p-4">
                <div class="mb-2">
                  <StageTag stage={note.data.stage} />
                </div>
                <a href={`/notes/${note.id}/`} class="font-semibold hover:text-accent">
                  {note.data.title}
                </a>
                <p class="mt-1 text-xs text-foreground/70">
                  {note.data.date.toLocaleDateString("it-IT")}
                </p>
                {note.data.summary && <p class="mt-2 text-sm text-foreground/85">{note.data.summary}</p>}
              </li>
            ))}
          </ul>
        )
      }
    </section>

    <section class="border-t border-border pt-10 pb-6">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-2xl font-semibold tracking-wide">Ultimi TIL</h2>
        <a href="/til" class="text-sm hover:text-accent">Tutti i TIL</a>
      </div>

      {
        recentTil.length === 0 ? (
          <p class="text-sm text-foreground/70">Nessun TIL pubblicato.</p>
        ) : (
          <ul class="space-y-3">
            {recentTil.map(entry => (
              <li class="rounded-xl border border-border p-4">
                <a href={`/til/${entry.id}/`} class="font-semibold hover:text-accent">
                  {entry.data.title}
                </a>
                <p class="mt-1 text-xs text-foreground/70">
                  {entry.data.date.toLocaleDateString("it-IT")}
                </p>
                <div class="mt-2 flex flex-wrap gap-2">
                  {entry.data.tags.map(tag => (
                    <span class="rounded-full border border-border px-2 py-0.5 text-xs">#{tag}</span>
                  ))}
                </div>
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    sessionStorage.setItem("backUrl", "/");
  });
</script>
